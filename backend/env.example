# Dress-Code Backend Environment Variables
# Copy this file to .env and fill in your values

GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001

# ── Model Preferences (optional) ─────────────────────────────
# Controls which model is tried first. Auto-falls back to next on rate limit.
# See config/models.js for full list of available models.

PREFERRED_TEXT_MODEL=gemini-2.5-flash
PREFERRED_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# ── Third Party APIs ──────────────────────────────────────
# Required if you want to use the free FLUX.1 or Stable Diffusion models
HF_TOKEN=your_huggingface_token_here
STABILITY_API_KEY=your_stability_api_key_here
FAL_KEY=your_fal_ai_key_here
